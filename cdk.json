{
  "app": "python3 app.py",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "**/__pycache__/**", "frontend/**"]
  },
  "context": {
    "admin_email": "ops-team@example.com",
    "org_admin_role_arn": "arn:aws:iam::MANAGEMENT_ACCOUNT:role/OrganizationAccountAccessRole",
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/aws-cloudfront-origins:useOriginAccessIdentityV2": true,
    "@aws-cdk/core:enablePartitionLiterals": true
  }
}
